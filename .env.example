# Copy to .env (or set in your shell) and fill in your values
# Only VAULT_PATH is required; all others have sensible defaults.

VAULT_PATH=/absolute/path/to/your/obsidian/vault

# Optional — override config file locations
# CLIENTS_PATH=/absolute/path/to/clients.json
# TECHNIK_CATEGORIES_PATH=/absolute/path/to/technik-categories.json
# TAG_ALIASES_PATH=/absolute/path/to/tag-aliases.json

# Optional — override log/state locations (defaults under /tmp)
# HARVESTER_LOG=/tmp/knowledge-harvester.log
# HARVESTER_STATE_DIR=/tmp/knowledge-harvester-state
# HARVESTER_SUGGESTIONS_LOG=/tmp/knowledge-harvester-suggestions.log
# TECHNIK_SUGGESTIONS_LOG=/tmp/technik-suggestions.log
